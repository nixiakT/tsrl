{
  "experiment_name": "synthetic_regime",
  "seed": 11,
  "data": {
    "source": "synthetic",
    "window_size": 32,
    "train_ratio": 0.8,
    "val_ratio": 0.1,
    "price_column": "price",
    "synthetic": {
      "steps": 2600,
      "drift": 0.0016,
      "volatility": 0.006,
      "seasonality": 0.003
    }
  },
  "env": {
    "name": "regime-v0",
    "reward_scale": 1.0,
    "episode_horizon": 192,
    "random_reset": true,
    "params": {
      "forecast_horizon": 8,
      "regime_threshold": 0.002
    }
  },
  "encoder": {
    "name": "returns-context-v0",
    "params": {}
  },
  "agent": {
    "name": "linear-ppo",
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "policy_lr": 0.03,
    "value_lr": 0.05,
    "gradient_clip": 5.0,
    "params": {
      "clip_epsilon": 0.15,
      "update_epochs": 5
    }
  },
  "trainer": {
    "episodes": 60,
    "val_episodes": 1,
    "eval_episodes": 1,
    "log_interval": 10,
    "eval_interval": 10,
    "selection_metric": "mean_terminal_score",
    "selection_mode": "max",
    "save_best": true,
    "early_stop_patience": null,
    "checkpoint_dir": "runs/synthetic_regime"
  }
}
